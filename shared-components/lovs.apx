lov static-fruits (
    name: STATIC_FRUITS
    source {
        location: staticValues
    }

    entry apple (
        sequence: 10
        display: Apple
        return: APPLE
    )

    entry banana (
        sequence: 40
        display: Banana
        return: BANANA
    )

    entry orange (
        sequence: 20
        display: Orange
        return: ORANGE
    )

    entry pear (
        sequence: 30
        display: Pear
        return: PEAR
    )

    entry watermelon (
        sequence: 50
        display: Watermelon
        return: WATERMELON
    )

)

